# Used when building for local production + ngrok (see scripts/run-ngrok-production.sh).
# The run script writes .env.production from your live ngrok URL — do not commit .env.production.

# Same-origin API through the local gateway (ngrok → :8088 → Next or backend)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SITE_URL=https://your-subdomain.ngrok-free.app

# SSR/build-time proxy to the local backend (not exposed to the browser)
API_INTERNAL_URL=http://127.0.0.1:4005

# Socket.IO through the same ngrok URL (gateway proxies /socket.io → backend)
NEXT_PUBLIC_WS_URL=https://your-subdomain.ngrok-free.app
